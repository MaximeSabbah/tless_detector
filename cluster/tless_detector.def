Bootstrap: docker
From: nvcr.io/nvidia/pytorch:23.10-py3

%post
    apt-get update -q && apt-get install -y -q \
        git wget libglib2.0-0 libsm6 libxext6 libxrender1 \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Critical pins — these exact combinations are confirmed working
    pip install --no-cache-dir \
        "torch==2.2.0" \
        "torchvision==0.17.0" \
        "numpy>=1.21,<2.0"

    # RTDETRv2 requirements — versions can float
    pip install --no-cache-dir \
        "faster-coco-eval>=1.6.6" \
        PyYAML \
        tensorboard \
        scipy \
        pycocotools \
        onnx \
        "onnxruntime-gpu" \
        tqdm \
        matplotlib \
        trimesh \
        "huggingface_hub>=0.20" \
        onnxsim \
        opencv-python-headless

%environment
    export PYTHONUNBUFFERED=1
    export OMP_NUM_THREADS=1
    export MKL_NUM_THREADS=1

%labels
    Author  msabbah@laas.fr
    Purpose RT-DETR v2 training for T-LESS objects
    Base    nvcr.io/nvidia/pytorch:23.10-py3
    Torch   2.2.0 + torchvision 0.17.0