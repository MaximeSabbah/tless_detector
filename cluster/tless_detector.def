Bootstrap: docker
From: nvcr.io/nvidia/pytorch:23.10-py3

%post
    apt-get update -q && apt-get install -y -q \
        git wget libglib2.0-0 libsm6 libxext6 libxrender1 \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir \
        "numpy>=1.21,<2.0" \
        "huggingface_hub>=0.20" \
        "onnx>=1.14" \
        "onnxruntime-gpu<1.19" \
        onnxsim \
        pycocotools \
        opencv-python-headless \
        matplotlib \
        tqdm \
        scipy \
        trimesh

%environment
    export PYTHONUNBUFFERED=1
    export OMP_NUM_THREADS=1
    export MKL_NUM_THREADS=1

%labels
    Author  msabbah@laas.fr
    Purpose RT-DETR training for T-LESS objects
    Base    nvcr.io/nvidia/pytorch:23.10-py3