Bootstrap: docker
From: nvcr.io/nvidia/pytorch:25.06-py3

%post
    apt-get update -q && apt-get install -y -q \
        libglib2.0-0 libsm6 libxext6 libxrender1 \
        && apt-get clean && rm -rf /var/lib/apt/lists/*

    # RT-DETR v2 official requirements (mirrors their Dockerfile exactly)
    pip install --upgrade pip
    pip install --no-cache-dir \
        "torch>=2.0.1" \
        "torchvision>=0.15.2" \
        "faster-coco-eval>=1.6.6" \
        PyYAML \
        tensorboard \
        scipy \
        pycocotools \
        onnx \
        onnxruntime-gpu

    # Extra packages required by this project only
    pip install --no-cache-dir \
        opencv-python-headless \
        tqdm \
        matplotlib \
        trimesh \
        "huggingface_hub>=0.20" \
        onnxsim

%environment
    export PYTHONUNBUFFERED=1
    export OMP_NUM_THREADS=1
    export MKL_NUM_THREADS=1

%labels
    Author  msabbah@laas.fr
    Purpose RT-DETR v2 training for T-LESS objects
    Base    nvcr.io/nvidia/pytorch:25.06-py3 (RT-DETR v2 official base)
